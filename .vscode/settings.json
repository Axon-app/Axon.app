{
    // React y JavaScript
    "files.associations": {
        "*.jsx": "javascriptreact",
        "*.js": "javascript",
        "*.ts": "typescript",
        "*.tsx": "typescriptreact",
        "*.java": "plaintext"
    },
    "emmet.includeLanguages": {
        "javascriptreact": "html"
    },
    "emmet.triggerExpansionOnTab": true,
    // ESLint optimizado
    "eslint.workingDirectories": [
        {
            "directory": ".",
            "changeProcessCWD": true
        }
    ],
    "eslint.validate": [
        "javascript",
        "javascriptreact"
    ],
    "eslint.format.enable": true,
    // TypeScript/JavaScript
    "typescript.preferences.includePackageJsonAutoImports": "off",
    "javascript.preferences.quoteStyle": "double",
    "typescript.preferences.quoteStyle": "double",
    // Tailwind CSS
    "tailwindCSS.includeLanguages": {
        "html": "html",
        "javascript": "javascript",
        "javascriptreact": "javascriptreact"
    },
    "tailwindCSS.experimental.classRegex": [
        [
            "clsx\\(([^)]*)\\)",
            "(?:'|\"|`)([^']*)(?:'|\"|`)"
        ],
        [
            "className\\s*:\\s*['\"`]([^'\"`]*)['\"`]"
        ]
    ],
    // Formateo automático optimizado
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit"
    }, // Rendimiento y productividad ULTRA OPTIMIZADO
    "editor.quickSuggestions": {
        "strings": true,
        "comments": true,
        "other": true
    },
    "editor.quickSuggestionsDelay": 10,
    "editor.suggest.insertMode": "replace",
    "editor.suggest.preview": true,
    "editor.suggest.shareSuggestSelections": false,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.tabCompletion": "on",
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.showKeywords": false,
    "editor.suggest.showSnippets": false,
    "editor.suggest.showWords": false,
    "editor.suggest.localityBonus": true,
    "editor.suggest.filterGraceful": true,
    // Configuraciones para mejor rendimiento con Copilot
    "editor.parameterHints.enabled": true,
    "editor.hover.delay": 300,
    "editor.hover.sticky": true,
    // GitHub Copilot - Configuración ULTRA OPTIMIZADA
    "github.copilot.enable": {
        "*": true,
        "yaml": true,
        "plaintext": false,
        "markdown": true,
        "javascript": true,
        "javascriptreact": true,
        "typescript": true,
        "typescriptreact": true,
        "html": true,
        "css": true,
        "json": true,
        "jsonc": true,
        "java": false
    },
    // Configuración avanzada para máxima precisión
    "github.copilot.advanced": {
        "secret_key": "github-copilot",
        "length": 800,
        "temperature": 0.05,
        "top_p": 0.95,
        "stop": [
            "\n\n",
            "\n//",
            "\n/*"
        ],
        "indentationMode": {
            "javascript": "space",
            "javascriptreact": "space",
            "typescript": "space",
            "css": "space",
            "html": "space",
            "json": "space"
        }
    },
    // Configuraciones de inline suggestions optimizadas
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "always",
    "editor.inlineSuggest.suppressSuggestions": false,
    // Configuraciones específicas de Copilot Chat
    "github.copilot.chat.enabled": true,
    "github.copilot.chat.welcomeMessage": "never",
    // Configuraciones adicionales para velocidad
    "github.copilot.autocomplete.enable": true,
    "github.copilot.conversation.enable": true,
    // Archivos y exclusiones
    "files.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/.git": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true
    },
    // CSS y estilos
    "css.validate": false,
    "scss.validate": false,
    "less.validate": false,
    // Terminal optimizado
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 14, // Vite y desarrollo
    "vite.devCommand": "npm run dev",
    "vite.buildCommand": "npm run build", // Deshabilitar extensiones de Java para proyecto React - DEFINITIVO
    "java.enabled": false,
    "java.compile.nullAnalysis.mode": "disabled",
    "java.import.gradle.enabled": false,
    "java.import.maven.enabled": false,
    "java.server.launchMode": "LightWeight",
    "java.sharedIndexes.enabled": "off",
    "java.autobuild.enabled": false,
    "java.import.generatesMetadataFilesAtProjectRoot": false,
    "java.jdt.ls.java.home": null,
    "java.configuration.runtimes": [],
    "java.eclipse.downloadSources": false,
    "java.maven.downloadSources": false,
    "java.debug.settings.enableRunDebugCodeLens": false,
    "java.test.enabled": false,
    "java.dependency.enabled": false,
    "java.references.includeDecompiledSources": false,
    "java.saveActions.organizeImports": false,
    "java.signatureHelp.enabled": false,
    "java.contentProvider.preferred": "",
    "java.import.exclusions": [
        "**"
    ],
    "redhat.telemetry.enabled": false, // Desactivar completamente el soporte de Java Language Server
    "java.jdt.ls.enabled": false,
    "java.ls.lombokSupport.enabled": false,
    "java.cleanup.actions": [],
    "java.completion.enabled": false,
    "java.hover.enabled": false,
    "java.format.enabled": false,
    "java.codeGeneration.hashCodeEquals.useJava7Objects": false,
    // Configuraciones adicionales para evitar Java completamente
    "workbench.editorAssociations": {
        "*.java": "default"
    },
    // Exclusiones específicas para Java
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/tmp/**": true,
        "**/*.jar": true,
        "**/*.class": true,
        "**/target/**": true,
        "**/.gradle/**": true,
        "**/build/**": true
    },
    // === CONFIGURACIONES ADICIONALES PARA COPILOT ULTRA OPTIMIZADO ===
    // Configuraciones de lenguaje específicas para mejor contexto
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.suggest.insertMode": "replace",
        "editor.inlineSuggest.enabled": true
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.suggest.insertMode": "replace",
        "editor.inlineSuggest.enabled": true
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.suggest.insertMode": "replace",
        "editor.inlineSuggest.enabled": true
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.suggest.insertMode": "replace",
        "editor.inlineSuggest.enabled": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.inlineSuggest.enabled": true
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.inlineSuggest.enabled": true
    },
    // Configuraciones de rendimiento específicas
    "editor.semanticHighlighting.enabled": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.lightbulb.enabled": "onCode",
    // Optimizaciones de memoria para proyectos grandes
    "typescript.disableAutomaticTypeAcquisition": true,
    "typescript.preferences.useAliasesForRenames": false,
    "typescript.suggest.autoImports": false,
    "javascript.suggest.autoImports": false,
    // Configuraciones para evitar conflictos con Copilot
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestOnTriggerCharacters": true,
    "editor.wordBasedSuggestionsMode": "off",
    // Configuraciones de workspace para mejor contexto
    "search.smartCase": true,
    "search.useGlobalIgnoreFiles": true,
    "search.useParentIgnoreFiles": true
}