{
  // ===== Asociaciones de archivos para un reconocimiento correcto de sintaxis =====
  "files.associations": {
    "*.jsx": "javascriptreact",
    "*.js": "javascript",
    "*.ts": "typescript",
    "*.tsx": "typescriptreact"
  },
  // ===== Configuración general del editor =====
  "editor.formatOnSave": true, // Formatea automáticamente al guardar
  "editor.formatOnPaste": true, // Formatea al pegar código
  "editor.formatOnType": true, // Formatea mientras escribes
  "editor.defaultFormatter": "dbaeumer.vscode-eslint", // Usa ESLint como formateador principal
  "editor.tabSize": 2, // Indentación de 2 espacios
  "editor.insertSpaces": true, // Usa espacios en vez de tabs
  "editor.detectIndentation": true, // Detecta indentación automáticamente
  // ===== Autoguardado y limpieza de archivos =====
  "files.autoSave": "onFocusChange", // Guarda automáticamente al cambiar de ventana
  "files.trimTrailingWhitespace": true, // Elimina espacios al final de línea
  "files.insertFinalNewline": true, // Añade salto de línea al final de archivo
  "files.trimFinalNewlines": true, // Elimina saltos de línea extra al final
  // ===== Configuración para React y JavaScript =====
  "emmet.includeLanguages": {
    "javascriptreact": "html",
    "typescript": "html",
    "typescriptreact": "html"
  },
  "emmet.triggerExpansionOnTab": true, // Expande Emmet con Tab
  // ===== ESLint =====
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit", // Corrige errores ESLint al guardar
    "source.organizeImports": "explicit" // Organiza imports al guardar
  },
  // ===== Preferencias de comillas y actualización de imports =====
  "javascript.preferences.quoteStyle": "double",
  "typescript.preferences.quoteStyle": "double",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  // ===== GitHub Copilot - Configuración Optimizada para Velocidad =====
  "github.copilot.enable": {
    "*": true, // Habilita Copilot en todos los lenguajes
    "plaintext": false, // Deshabilita en texto plano para mejor rendimiento
    "markdown": true, // Habilita en Markdown
    "yaml": false, // Deshabilita en YAML para velocidad
    "json": true, // Habilita en JSON
    "log": false // Deshabilita en logs para rendimiento
  },
  "github.copilot.advanced": {
    "length": 500, // Longitud optimizada para velocidad (reduce latencia)
    "temperature": 0.1, // Baja temperatura para respuestas más rápidas y precisas
    "top_p": 0.9, // Optimiza selección de tokens
    "indentationMode": "automatic", // Indentación automática
    "listCount": 3, // Reduce número de sugerencias para mayor velocidad
    "inlineSuggestCount": 3 // Limita sugerencias inline para rendimiento
  },
  "github.copilot.chat": {
    "localeOverride": "es", // Copilot Chat en español
    "maxTokens": 4000, // Reducido para respuestas más rápidas
    "temperature": 0.1, // Baja temperatura para velocidad
    "welcomeMessage": "enabled", // Habilita mensajes de bienvenida
    "streaming": true, // Habilita streaming para respuestas más rápidas
    "cacheEnabled": true // Habilita caché para mejorar velocidad
  },
  // ===== Configuraciones adicionales de rendimiento =====
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.quickSuggestionsDelay": 0, // Sin delay para sugerencias más rápidas
  "editor.suggestOnTriggerCharacters": true, // Sugerencias al escribir caracteres especiales
  "editor.acceptSuggestionOnCommitCharacter": true, // Acepta sugerencias rápidamente
  "editor.acceptSuggestionOnEnter": "on", // Acepta con Enter
  "editor.wordBasedSuggestions": "off", // Desactiva sugerencias basadas en palabras para usar solo Copilot
  // ===== Optimizaciones de rendimiento general =====
  "extensions.autoUpdate": false, // Desactiva actualizaciones automáticas para mayor estabilidad
  "telemetry.telemetryLevel": "off", // Desactiva telemetría para mejor rendimiento
  "workbench.enableExperiments": false, // Desactiva experimentos
  "workbench.settings.enableNaturalLanguageSearch": false, // Desactiva búsqueda en lenguaje natural
  // ===== Optimizaciones de memoria y caché =====
  "search.useGlobalIgnoreFiles": true, // Usa archivos .gitignore para búsquedas más rápidas
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.git": true,
    "**/.DS_Store": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  // ===== Configuración específica de lenguaje =====
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  }
}
