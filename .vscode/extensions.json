{
  // === Extensiones recomendadas para el desarrollo profesional en Axon.App ===
  "recommendations": [
    // Asistente de IA (GitHub Copilot y chat)
    "github.copilot",
    "github.copilot-chat",

    // Soporte para React, Vite y herramientas modernas
    "dbaeumer.vscode-eslint", // Linting y formato de JS/JSX
    "bradlc.vscode-tailwindcss", // Autocompletado y validación de Tailwind
    "ms-vscode.vscode-typescript-next", // Mejor soporte para TypeScript moderno
    "dsznajder.es7-react-js-snippets", // Snippets útiles para React

    // Productividad y edición
    "christian-kohler.path-intellisense", // Autocompletado de rutas
    "formulahendry.auto-rename-tag", // Renombrado automático de etiquetas
    "formulahendry.auto-close-tag", // Cierre automático de etiquetas
    "wayou.vscode-todo-highlight", // Resalta TODOs y FIXMEs

    // Control de versiones y visualización de historial
    "eamodio.gitlens", // Potente visualización de historial Git
    "mhutchie.git-graph", // Gráfica de ramas y commits

    // Debugging y análisis de rendimiento
    "ms-vscode.vscode-js-debug", // Depuración avanzada de JS
    "wix.vscode-import-cost", // Muestra el tamaño de los imports

    // Formato y validación de archivos de configuración
    "ms-vscode.vscode-json", // Soporte avanzado para JSON
    "mikestead.dotenv" // Soporte para archivos .env
  ],
  // === Extensiones NO recomendadas (pueden causar conflictos o no aportan valor) ===
  "unwantedRecommendations": [
    // Alternativas de IA y autocompletado (conflicto con Copilot)
    "tabnine.tabnine-vscode",
    "visualstudioexptteam.vscodeintellicode",
    "ms-vscode.vscode-ai-toolkit",

    // Formateadores alternativos (se recomienda usar ESLint)
    "esbenp.prettier-vscode",

    // Diagnóstico visual redundante (ya cubierto por ESLint)
    "usernamehw.errorlens",
    "ms-vscode.vscode-error-lens",

    // Correctores ortográficos (no necesarios para este proyecto)
    "streetsidesoftware.code-spell-checker",
    "streetsidesoftware.code-spell-checker-spanish",
    "ban.spellright",

    // Lenguajes no utilizados en el stack del proyecto
    "vscjava.vscode-java-pack",
    "ms-python.python",
    "ms-dotnettools.csharp",
    "ms-vscode.cpptools",
    "golang.go",
    "rust-lang.rust",

    // Características de GitHub no necesarias localmente
    "ms-vscode.remote-repositories",
    "github.codespaces"
  ]
}
